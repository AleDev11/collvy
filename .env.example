# Neon — PostgreSQL connection string
# Get it from: https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""
# Local: http://localhost:3000 | Production: https://your-domain.com
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=""
# Webhook secret — from: stripe listen --forward-to localhost:3000/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs — create them in: https://dashboard.stripe.com/products
# Set metadata tier=PRO or tier=BUSINESS on each price
# STRIPE_PRICE_PRO_MONTHLY=""
# STRIPE_PRICE_PRO_ANNUAL=""
# STRIPE_PRICE_BUSINESS_MONTHLY=""
# STRIPE_PRICE_BUSINESS_ANNUAL=""
